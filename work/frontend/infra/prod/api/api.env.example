NODE_ENV=production
PORT=8080

# 站点来源（用于 CORS + 回跳链接）
# 支持逗号分隔的多域名（例如：https://younov.com,https://www.younov.com）
WEB_ORIGIN=https://younov.com,https://www.younov.com

# 数据库（主库，wg0 内网）
# 如果使用 pgBouncer（本机），请改为 127.0.0.1:6432
DATABASE_URL=postgresql://younov:CHANGE_ME_PASSWORD@10.50.0.4:5432/younov?schema=public

# Redis（建议开启 requirepass，wg0 内网）
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@10.50.0.6:6379

# 会话/鉴权
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
AUTH_COOKIE_NAME=younov_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# 计费模式：mock（演示）| stripe（真实支付）
BILLING_MODE=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_SVIP=
BILLING_SUCCESS_URL=https://younov.com/subscription?status=success
BILLING_CANCEL_URL=https://younov.com/subscription?status=cancel

# 可选：IP 白名单（disabled | allowlist）
IP_WHITELIST_MODE=disabled

# 种子账号（首次 seed 用）
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=admin123456
DEMO_USER_EMAIL=user@example.com
DEMO_USER_PASSWORD=user123456

