PORT=8080
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@db:5432/younov?schema=public

# 双 API/双库回退：本机无数据时请求的对端 API 地址（如 http://10.50.0.3:8080）
# 服务器 A 填 B 的地址，服务器 B 填 A 的地址；不设则不做回退
PEER_API_URL=
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me
JWT_EXPIRES_IN=14d
AUTH_COOKIE_NAME=younov_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
IP_WHITELIST_MODE=disabled

# 计费模式：mock（演示）| stripe（真实支付）
BILLING_MODE=mock

# Stripe（占位，后续你补齐密钥/PriceId 即可）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_SVIP=
BILLING_SUCCESS_URL=http://localhost/subscription?status=success
BILLING_CANCEL_URL=http://localhost/subscription?status=cancel

ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=admin123456
DEMO_USER_EMAIL=user@example.com
DEMO_USER_PASSWORD=user123456

